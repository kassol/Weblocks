{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022"]
  },
  "include": [
    "src/build/**/*.ts",
    "src/challenge/**/*.ts",
    "src/definitions/**/*.ts",
    "src/math/**/*.ts",
    "src/session/**/*.ts",
    "src/storage/**/*.ts",
    "src/index.ts"
  ]
}
